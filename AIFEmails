def append_sales_ops_cc(cc_mail):
    extra = ["cci.pricing@canon-europe.com"]

    if not cc_mail:
        return extra

    if isinstance(cc_mail, str):
        return [cc_mail] + extra

    return list(set(cc_mail + extra))  # avoid duplicates

if new_status == AifStatusChoices.CLOSED:
