def build_sales_ops_cc(cc_mail):
    extra = "cci.pricing@canon-europe.com"

    if not cc_mail:
        return extra

    # if already string → append
    if isinstance(cc_mail, str):
        return f"{cc_mail};{extra}"

    # if list → join
    if isinstance(cc_mail, list):
        return ";".join([*cc_mail, extra])

    return extra

